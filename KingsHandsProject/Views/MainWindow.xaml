<Window
    x:Class="KingsHandsProject.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:infra="clr-namespace:KingsHandsProject.Infrastructure"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:KingsHandsProject.Models"
    Title="KingsHandsProject"
    Width="1100"
    Height="600"
    MinWidth="900"
    MinHeight="500"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infra:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Height="32"
                VerticalContentAlignment="Center"
                Text="{Binding SelectedFolderPath, UpdateSourceTrigger=PropertyChanged}" />

            <Button
                Grid.Column="2"
                Width="110"
                Height="32"
                Command="{Binding BrowseFolderCommand}"
                Content="Обзор..." />

            <Button
                Grid.Column="4"
                Width="170"
                Height="32"
                Command="{Binding StartScanCommand}"
                Content="Начать сканирование" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Столы" />

                    <Grid Grid.Row="2">
                        <ListBox ItemsSource="{Binding TableNames}" SelectedItem="{Binding SelectedTableName, Mode=TwoWay}" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            Text="{Binding TablePlaceholderText}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasTables, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Раздачи" />

                    <Grid Grid.Row="2">
                        <ListBox ItemsSource="{Binding HandItems}" SelectedItem="{Binding SelectedHand, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PokerHand}">
                                    <TextBlock Text="{Binding HandId}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            Text="{Binding HandPlaceholderText}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasHandItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Column="4"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Детали" />

                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding HasSelectedHand, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Игроки:" />
                                <TextBlock
                                    Margin="0,4,0,12"
                                    Text="{Binding PlayersText}"
                                    TextWrapping="Wrap" />

                                <TextBlock FontWeight="SemiBold" Text="Победители:" />
                                <TextBlock
                                    Margin="0,4,0,12"
                                    Text="{Binding WinnersText}"
                                    TextWrapping="Wrap" />

                                <TextBlock FontWeight="SemiBold" Text="Сумма выигрыша:" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Text="{Binding WinAmountText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Gray"
                            Text="{Binding DetailsPlaceholderText}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasSelectedHand, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="4"
            Padding="8"
            BorderBrush="#D0D0D0"
            BorderThickness="1">
            <TextBlock
                VerticalAlignment="Center"
                Text="{Binding StatusText}"
                TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>